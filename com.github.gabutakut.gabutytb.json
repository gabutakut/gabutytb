{
  "app-id": "com.github.gabutakut.gabutytb",
  "runtime": "org.gnome.Platform",
  "runtime-version": "47",
  "sdk": "org.gnome.Sdk",
  "command": "gabutytb",
  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--device=dri"
  ],
  "modules": [
    {
      "name": "python3-setuptools",
      "buildsystem": "simple",
      "build-commands": [],
      "sources": []
    },
    {
      "name": "python3-yt-dlp",
      "buildsystem": "simple",
      "build-commands": [
        "pip3 install --no-index --find-links=. --prefix=${FLATPAK_DEST} yt_dlp-*.whl"
      ],
      "sources": [
        {
          "type": "file",
          "url": "https://files.pythonhosted.org/packages/py3/y/yt_dlp/yt_dlp-2024.12.13-py3-none-any.whl",
          "sha256": "REPLACE_WITH_ACTUAL_SHA256",
          "dest-filename": "yt_dlp-2024.12.13-py3-none-any.whl"
        }
      ]
    },
    {
      "name": "gabutytb",
      "buildsystem": "meson",
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ]
    }
  ]
}
